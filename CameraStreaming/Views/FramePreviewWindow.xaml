<Window x:Class="CameraStreaming.Views.FramePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CameraStreaming"
        xmlns:svc="clr-namespace:CameraStreaming.Services"
        Title="{Binding [Preview_Title], Source={x:Static svc:LocalizationService.Instance}}" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E"
        Icon="/Icons/app.ico"
        KeyDown="Window_KeyDown"
        Closed="Window_Closed">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频显示区域 -->
        <Border Grid.Row="0" Margin="8" BorderBrush="#444444" BorderThickness="1"
                Background="Black" CornerRadius="4">
            <Image x:Name="previewImage" Stretch="Uniform"/>
        </Border>

        <!-- 底部工具栏 -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnMirror" Content="{Binding [Mirror], Source={x:Static svc:LocalizationService.Instance}}" Width="76" Height="32"
                        Margin="0,0,8,0" Click="btnMirror_Click" Style="{DynamicResource ToolButtonStyle}"/>
                <Button x:Name="btnCopy" Content="{Binding [CopyToClipboard], Source={x:Static svc:LocalizationService.Instance}}" Width="160" Height="32"
                        Margin="0,0,8,0" Click="btnCopy_Click" Style="{DynamicResource ToolButtonStyle}"/>
                <Button x:Name="btnSave" Content="{Binding [SaveToFile], Source={x:Static svc:LocalizationService.Instance}}" Width="150" Height="32"
                        Margin="0,0,8,0" Click="btnSave_Click" Style="{DynamicResource ToolButtonStyle}"/>
                <Button x:Name="btnClose" Content="{Binding [Close], Source={x:Static svc:LocalizationService.Instance}}" Width="100" Height="32"
                        Click="btnClose_Click" Style="{DynamicResource ToolButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>

    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4D4D4D"/>
                                <Setter Property="BorderBrush" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
