<Window x:Class="CameraStreaming.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CameraStreaming"
        xmlns:svc="clr-namespace:CameraStreaming.Services"
        Title="{Binding [Settings_Title], Source={x:Static svc:LocalizationService.Instance}}" Height="470" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Icon="/Icons/app.ico"
        Loaded="Window_Loaded">
    <StackPanel Margin="24">
        <!-- 标题 -->
        <TextBlock Text="{Binding [Settings_Header], Source={x:Static svc:LocalizationService.Instance}}" FontSize="18" FontWeight="Bold"
                   Foreground="#E0E0E0" Margin="0,0,0,16"/>

        <!-- 分隔线 -->
        <Rectangle Height="1" Fill="#444444" Margin="0,0,0,16"/>

        <!-- 摄像头选择 -->
        <DockPanel Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left" Width="80" Text="{Binding [CameraLabel], Source={x:Static svc:LocalizationService.Instance}}" Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Grid>
                <ComboBox x:Name="cmbCameras" Height="32" IsEnabled="False"
                          Style="{DynamicResource ComboStyle}"/>
                <TextBlock x:Name="txtLoading" Text="{Binding [DetectingCameras], Source={x:Static svc:LocalizationService.Instance}}" VerticalAlignment="Center"
                           Margin="10,0,0,0" Foreground="#888888" FontSize="12"/>
            </Grid>
        </DockPanel>

        <!-- 分辨率选择 -->
        <DockPanel Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left" Width="80" Text="{Binding [ResolutionLabel], Source={x:Static svc:LocalizationService.Instance}}" Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox x:Name="cmbResolution" Height="32"
                      Style="{DynamicResource ComboStyle}">
                <ComboBoxItem Content="640 x 480" Tag="640,480"/>
                <ComboBoxItem Content="1280 x 720" Tag="1280,720"/>
                <ComboBoxItem Content="1920 x 1080" Tag="1920,1080"/>
                <ComboBoxItem Content="640 x 360" Tag="640,360"/>
            </ComboBox>
        </DockPanel>

        <!-- 帧率选择 -->
        <DockPanel Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left" Width="80" Text="{Binding [FpsLabel], Source={x:Static svc:LocalizationService.Instance}}" Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox x:Name="cmbFps" Height="32"
                      Style="{DynamicResource ComboStyle}">
                <ComboBoxItem Content="15 fps" Tag="15"/>
                <ComboBoxItem Content="30 fps" Tag="30"/>
                <ComboBoxItem Content="60 fps" Tag="60"/>
            </ComboBox>
        </DockPanel>

        <!-- 语言选择 -->
        <DockPanel Margin="0,0,0,12">
            <TextBlock x:Name="txtLanguageLabel" DockPanel.Dock="Left" Width="80" Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox x:Name="cmbLanguage" Height="32"
                      Style="{DynamicResource ComboStyle}" SelectionChanged="cmbLanguage_SelectionChanged">
                <ComboBoxItem Content="中文" Tag="zh-CN" IsSelected="True"/>
                <ComboBoxItem Content="English" Tag="en-US"/>
            </ComboBox>
        </DockPanel>

        <!-- 窗口形状 -->
        <DockPanel Margin="0,0,0,0">
            <TextBlock x:Name="txtWindowShapeLabel" DockPanel.Dock="Left" Width="80" Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox x:Name="cmbWindowShape" Height="32"
                      Style="{DynamicResource ComboStyle}">
                <ComboBoxItem Content="{Binding [CircleMode], Source={x:Static svc:LocalizationService.Instance}}" Tag="circle" IsSelected="True"/>
                <ComboBoxItem Content="{Binding [SquareMode], Source={x:Static svc:LocalizationService.Instance}}" Tag="square"/>
            </ComboBox>
        </DockPanel>

        <!-- 分隔线 -->
        <Rectangle Height="1" Fill="#444444" Margin="0,16,0,16"/>

        <!-- 按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnOK" Content="{Binding [OK], Source={x:Static svc:LocalizationService.Instance}}" Width="90" Height="34" Margin="0,0,8,0"
                    Click="btnOK_Click" Style="{DynamicResource DialogButtonStyle}"/>
            <Button x:Name="btnCancel" Content="{Binding [Cancel], Source={x:Static svc:LocalizationService.Instance}}" Width="90" Height="34"
                    Click="btnCancel_Click" Style="{DynamicResource DialogButtonCancelStyle}"/>
        </StackPanel>
    </StackPanel>

    <Window.Resources>
        <!-- 全局 ComboBoxItem 样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3D5A80"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D5A80"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"/>
                            <ToggleButton IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" Margin="8,0,0,0"
                                                              VerticalAlignment="Center"
                                                              Content="{TemplateBinding Content}"
                                                              TextBlock.Foreground="#E0E0E0"/>
                                            <Path Grid.Column="1" Data="M0,0 L6,6 L12,0" Stroke="#999999"
                                                  StrokeThickness="1.5" Stretch="Uniform"
                                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                                  Margin="0,0,8,0"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" Margin="8,0,30,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextBlock.Foreground="#E0E0E0"/>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#2D2D2D" BorderBrush="#555555"
                                        BorderThickness="1" CornerRadius="4"
                                        Margin="0,2,0,0">
                                    <ScrollViewer Margin="2" MaxHeight="200"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButtonCancelStyle" TargetType="Button">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4D4D4D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
